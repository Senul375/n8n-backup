    {
      "parameters": {
        "jsCode": "const leads = items.map(item => item.json);\n\nconst priorityMap = {\n  \"ceo\": 1,\n  \"founder\": 2,\n  \"co-founder\": 3,\n  \"owner\": 4,\n  \"director\": 5,\n  \"manager\": 6,\n  \"head\": 7,\n  \"marketing\": 8\n};\n\nfunction getPriority(title) {\n  if (!title) return 999;\n\n  title = title.toLowerCase();\n\n  for (const key in priorityMap) {\n    if (title.includes(key)) {\n      return priorityMap[key];\n    }\n  }\n\n  return 999;\n}\n\nconst bestLeads = {};\nconst seenEmails = new Set();\n\nfor (const lead of leads) {\n\n  // Normalize domain\n  let domain = (lead.websiteUri || \"\")\n    .toLowerCase()\n    .replace(\"https://\", \"\")\n    .replace(\"http://\", \"\")\n    .replace(\"www.\", \"\")\n    .trim();\n\n  if (!domain) continue;\n\n  // Skip duplicate emails\n  const email = (lead.email || \"\").toLowerCase().trim();\n\n  if (seenEmails.has(email)) {\n    continue;\n  }\n\n  seenEmails.add(email);\n\n  const title = lead[\"job title\"] || \"\";\n  const currentPriority = getPriority(title);\n\n  if (\n    !bestLeads[domain] ||\n    currentPriority < bestLeads[domain].priority\n  ) {\n    bestLeads[domain] = {\n      priority: currentPriority,\n      data: lead\n    };\n  }\n}\n\nreturn Object.values(bestLeads).map(entry => ({\n  json: entry.data\n}));"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        752,
        240
      ],
