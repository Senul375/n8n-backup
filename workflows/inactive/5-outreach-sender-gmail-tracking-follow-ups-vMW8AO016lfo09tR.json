    {
      "parameters": {
        "jsCode": "const emailData = $('Build Email + Tracking').item.json;\nconst gmailResult = $json;\n\nconst threadId = gmailResult.threadId || gmailResult.id || null;\n\nreturn {\n  lead_id: emailData.lead_id,\n  sequence_id: emailData.sequence_id,\n  email_type: emailData.email_type,\n  subject: emailData.subject,\n  body: emailData.body_plain,\n  tracking_id: emailData.tracking_id,\n  gmail_thread_id: threadId,\n  status: 'sent',\n  sent_at: new Date().toISOString()\n};"
      },
