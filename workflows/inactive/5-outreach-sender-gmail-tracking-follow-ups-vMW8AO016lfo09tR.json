      "name": "Get Email Sequence",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        -2416,
        80
      ],
      "id": "a8b0ea33-143c-4b1d-95b1-73d707d4c1b0"
    },
    {
      "parameters": {
        "jsCode": "const webhookData = $('Webhook - Approve & Send').item.json.body;\nconst lead = $('Get Lead').item.json[0];\nconst seq = $('Get Email Sequence').item.json[0];\nconst emailType = webhookData.email_type || 'initial';\n\nconst trackingId = require('crypto').randomUUID();\n\nlet subject, body;\nif (emailType === 'initial') {\n  subject = seq.email_1_subject;\n  body = seq.email_1_body;\n} else if (emailType === 'fu1') {\n  subject = seq.fu1_subject;\n  body = seq.fu1_body;\n} else if (emailType === 'fu2') {\n  subject = seq.fu2_subject;\n  body = seq.fu2_body;\n} else if (emailType === 'fu3') {\n  subject = seq.fu3_subject;\n  body = seq.fu3_body;\n}\n\n// Wrap any URLs in body with tracked redirect\nconst trackingBase = $credentials.trackingBaseUrl || 'https://track.sncai.info';\nconst trackedBody = (body || '').replace(\n  /https?:\\/\\/[^\\s<>\"]+/g,\n  (url) => `${trackingBase}/click?tid=${trackingId}&url=${encodeURIComponent(url)}`\n);\n\n// Append invisible tracking pixel\nconst pixelUrl = `${trackingBase}/open?tid=${trackingId}`;\nconst htmlBody = `<div>${trackedBody.replace(/\\n/g, '<br>')}</div><img src=\"${pixelUrl}\" width=\"1\" height=\"1\" style=\"display:none\" />`;\n\nreturn {\n  lead_id: lead.id,\n  sequence_id: seq.id,\n  email_type: emailType,\n  to_email: lead.email,\n  to_name: lead.contact_name || lead.business_name,\n  subject,\n  body_plain: body,\n  body_html: htmlBody,\n  tracking_id: trackingId\n};"
      },
      "name": "Build Email + Tracking",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -2208,
        80
      ],
      "id": "ca143409-8c0f-4c30-9f41-a845d23078f1",
      "notes": "Injects open-tracking pixel and wraps links with click-tracking redirect. Set $credentials.trackingBaseUrl to your tracking server domain."
    },
    {
      "parameters": {
        "jsCode": "// Random wait between 3-7 minutes to avoid bot detection\nconst minMs = 3 * 60 * 1000;\nconst maxMs = 7 * 60 * 1000;\nconst waitMs = Math.floor(Math.random() * (maxMs - minMs + 1)) + minMs;\nconst waitSeconds = Math.floor(waitMs / 1000);\nreturn { ...($input.item.json), jitter_seconds: waitSeconds };"
      },
      "name": "Calculate Random Jitter",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -1984,
