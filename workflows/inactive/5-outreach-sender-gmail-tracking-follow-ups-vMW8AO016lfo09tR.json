    {
      "parameters": {
        "jsCode": "const data = $('Map Status Updates').item.json;\nconst emailType = data.email_type;\n\nconst delayDays = { initial: 3, fu1: 2, fu2: 2 };\nconst nextEmailMap = { initial: 'fu1', fu1: 'fu2', fu2: 'fu3' };\n\nif (emailType === 'fu3') {\n  return { schedule_next: false };\n}\n\nconst delay = delayDays[emailType];\nconst nextType = nextEmailMap[emailType];\nconst scheduledFor = new Date(Date.now() + delay * 24 * 60 * 60 * 1000).toISOString();\n\nreturn {\n  schedule_next: true,\n  lead_id: data.lead_id,\n  sequence_id: data.sequence_id,\n  next_email_type: nextType,\n  scheduled_for: scheduledFor\n};"
      },
