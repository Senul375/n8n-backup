    {
      "parameters": {
        "jsCode": "const logEntry = Array.isArray($json) ? $json[0] : $json;\nconst emailType = logEntry.email_type;\n\nconst statusMap = {\n  initial: { leadStatus: 'sent', seqField: 'sent_at' },\n  fu1: { leadStatus: 'fu1_sent', seqField: null },\n  fu2: { leadStatus: 'fu2_sent', seqField: null },\n  fu3: { leadStatus: 'fu3_sent', seqField: null }\n};\n\nconst mapping = statusMap[emailType] || statusMap['initial'];\n\nreturn {\n  lead_id: logEntry.lead_id,\n  sequence_id: logEntry.sequence_id,\n  email_type: emailType,\n  lead_status: mapping.leadStatus,\n  now: new Date().toISOString()\n};"
      },
