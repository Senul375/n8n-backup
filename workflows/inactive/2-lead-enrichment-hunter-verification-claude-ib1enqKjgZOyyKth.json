    {
      "parameters": {
        "jsCode": "const lead = $input.item.json;\nlet domain = lead.website || '';\ndomain = domain.replace(/^https?:\\/\\//i, '').replace(/^www\\./i, '').split('/')[0].split('?')[0];\nreturn { ...lead, domain };"
