      "name": "Hunter Found Emails?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [
        192,
        128
      ],
      "id": "9da7ff34-07a6-4e1f-8f7e-1dab902bf9e3"
    },
    {
      "parameters": {
        "jsCode": "const lead = $('Extract Domain').item.json;\nconst emails = $json.data.emails || [];\n\nconst priorityKeywords = ['owner','founder','ceo','director','manager','president','principal','partner'];\n\nlet best = emails.find(e => e.position && priorityKeywords.some(k => (e.position || '').toLowerCase().includes(k)));\n\nif (!best) {\n  best = emails.find(e => /^(info|contact|hello|admin|sales|enquiries|enquiry)@/i.test(e.value));\n}\n\nif (!best) {\n  best = emails[0];\n}\n\nconst contactName = [best.first_name, best.last_name].filter(Boolean).join(' ').trim();\n\nreturn {\n  ...lead,\n  email: best.value,\n  contact_name: contactName || null,\n  email_source: 'hunter'\n};"
      },
      "name": "Pick Best Email (Hunter)",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        416,
        0
      ],
      "id": "65249c95-13fd-4ecd-aaee-9b0708a2cd42"
    },
