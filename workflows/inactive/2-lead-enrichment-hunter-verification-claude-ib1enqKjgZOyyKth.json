      "id": "318b4dd9-5a79-4adf-b9e9-f0b756692e1d",
      "notes": "PLACEHOLDER ENDPOINT - this is not Lumrid's official documented API. Open browser dev tools (Network tab) while running a single verification on lumrid.com, find the actual request URL/method/payload/headers, and update this node to match. Also adjust 'Parse Verification Result' once you see the real response shape."
    },
    {
      "parameters": {
        "jsCode": "const lead = $json;\nconst verification = $('Verify Email (Lumrid)').item.json;\n\n// ADJUST these field names once you confirm Lumrid's actual response shape\nconst status = (verification.status || verification.result || 'unknown').toLowerCase();\nconst verified = status === 'valid' || status === 'good';\n\nreturn {\n  ...lead,\n  email_verified: verified,\n  email_verification_status: status\n};"
      },
