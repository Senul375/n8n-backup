        },
        "messages": {
          "values": [
            {
              "content": "=You are writing Follow Up 2 for a cold email sequence. The pitch and Follow Up 1 have already been sent with no reply.\n\nINPUTS:\n- Client first name: {{ $('Get row(s) in sheet1').first().json.first_name }}\n- Company name: {{ $('Get row(s) in sheet1').first().json.name }}\n- Sender name: {{ $('Edit Fields').first().json.your_name }}\n\nTASK:\nWrite a very short, direct Follow Up 2. No preamble, no context, no reference to previous emails. Just a straight ask.\n\nRULES:\n- Never say \"circling back\", \"following up\", \"just checking in\" or any line that is about you\n- Never use the word prototype, mockup, or demo — use \"example\" instead\n- Under 40 words total (body only, not counting subject)\n- Subject line: exactly 3 or 4 words\n- Sound like a real person sending a quick nudge\n- No corporate or AI-sounding words\n- Sign off: Best, [sender name]\n\nOUTPUT:\nReturn only valid JSON in this exact format, nothing else, no markdown, no explanation:\n{\"subject\": \"...\", \"body\": \"...\"}"
            }
          ]
        },
        "builtInTools": {},
        "options": {
          "maxOutputTokens": 1800
        }
      },
