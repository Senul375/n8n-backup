      "parameters": {
        "jsCode": "// This Code node expects input like:\n// { \"output\": \"{\\n  \\\"Company Name\\\": \\\"...\\\",\\n  \\\"Person Name\\\": [ ... ]\\n}\" }\n\nconst item = $input.item.json;\n\n// 1) Get the raw string from the Switch output\nconst rawText = (item.output || \"\").trim();\n\nif (!rawText) {\n  return [{\n    json: {\n      error: \"Missing 'output' field or it's empty\",\n      received: item\n    }\n  }];\n}\n\n// 2) rawText should already be JSON (starts with { or [), but we also support cases\n// where extra text appears and we need to extract the JSON block.\nlet jsonString = rawText;\n\n// If it doesn't start with { or [, try extracting the first JSON object/array\nif (!(jsonString.startsWith(\"{\") || jsonString.startsWith(\"[\"))) {\n  const objMatch = jsonString.match(/\\{[\\s\\S]*\\}/);\n  const arrMatch = jsonString.match(/\\[[\\s\\S]*\\]/);\n  const match = objMatch || arrMatch;\n\n  if (!match) {\n    return [{\n      json: {\n        error: \"No JSON found in 'output' string\",\n        received_text: rawText\n      }\n    }];\n  }\n\n  jsonString = match[0];\n}\n\n// 3) Parse\nlet parsed;\ntry {\n  parsed = JSON.parse(jsonString);\n} catch (e) {\n  return [{\n    json: {\n      error: \"JSON.parse failed on 'output'\",\n      details: e.message,\n      raw: rawText\n    }\n  }];\n}\n\n// 4) Normalize format:\n// If parsed is an array, try to find the first object that has \"Company Name\"\nlet data = parsed;\nif (Array.isArray(parsed)) {\n  data = parsed.find(x => x && typeof x === \"object\" && x[\"Company Name\"]) || parsed[0] || {};\n}\n\n// 5) Extract fields\nconst companyName = data[\"Company Name\"] || \"Unknown\";\nconst people = Array.isArray(data[\"Person Name\"]) ? data[\"Person Name\"] : [];\n\n// 6) If no people, return one item (keeps workflow stable)\nif (people.length === 0) {\n  return [{\n    json: {\n      company_name: companyName,\n      status: \"No people found\",\n      original: data\n    }\n  }];\n}\n\n// 7) Output one item per person\nreturn people.map(person => ({\n  json: {\n    company_name: companyName,\n    name: person?.name ?? \"NA\",\n    title: person?.title ?? \"NA\",\n    email: person?.email ?? \"NA\",\n    linkedin: person?.LinkedIn ?? \"NA\",\n    instagram: person?.Instagram ?? \"NA\",\n    twitter: person?.Twitter ?? \"NA\",\n    facebook: person?.Facebook ?? \"NA\"\n  }\n}));\n"
      },
